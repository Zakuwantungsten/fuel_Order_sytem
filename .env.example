# ============================================================
# Fuel Order — Environment Variable Template
# ============================================================
# Copy this file to backend/.env and fill in your values.
# NEVER commit the actual backend/.env to git — it has secrets.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ────────────────────────────────────────────
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fuel-order

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<32+ character random string>
JWT_REFRESH_SECRET=<different 32+ character random string>
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ── CORS ─────────────────────────────────────────────────────
# Add all origins that are allowed to call the API
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── Frontend URL (used in password reset emails) ─────────────
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── Email — choose ONE provider and fill in its keys ─────────
# Option A: SMTP (Gmail etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your-gmail>@gmail.com
SMTP_PASS=<gmail-app-password>

# Option B: SendGrid
SENDGRID_API_KEY=

# Option C: Mailjet
MAILJET_API_KEY=
MAILJET_API_SECRET=

# Option D: Resend (requires verified domain)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=FuelOrder

# Option E: Brevo
BREVO_API_KEY=

# ── Encryption Keys ──────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=<64 hex chars>
FIELD_ENCRYPTION_KEY=<64 hex chars>
BACKUP_ENCRYPTION_KEY=<64 hex chars>

# ── App Name (shows in authenticator app for MFA) ────────────
APP_NAME=FuelOrder

# ── Web Push (VAPID) ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:<your-email>@example.com

# ── Cloudflare R2 (file/backup storage) ──────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fuel-order-assets
R2_BACKUP_BUCKET_NAME=fuel-order-backups
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── Geolocation ──────────────────────────────────────────────
GEOLOCATION_PROVIDER=ipapi
# GEOLOCATION_API_KEY=   # only needed if using ipinfo

# ── Redis ────────────────────────────────────────────────────
# CVE-2025-49844 (RediShell, CVSS 10.0): Redis now requires a password.
# Generate with: openssl rand -base64 32
# This value must ALSO be set in the root-level .env (same dir as
# docker-compose.yml) so Compose can interpolate it into the Redis
# container command and the backend REDIS_URL override.
REDIS_PASSWORD=<strong-random-password>

# Docker Compose sets this automatically to redis://:PASSWORD@redis:6379.
# For local dev without Docker: redis://:PASSWORD@localhost:6379
# For cloud Redis (Upstash, Redis Cloud): paste your full URL here.
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ── Optional Integrations ────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Security hardening (production) ─────────────────────────
# Private alert channel — only this address gets critical security emails
SECURITY_ALERT_EMAIL=
SECURITY_ALERT_EMAIL_ONLY=true
# Coordinated-attack spike alert threshold (default 100 blocks / 10 min)
SECURITY_BLOCK_SPIKE_THRESHOLD=100
SECURITY_SUSPICIOUS_THRESHOLD=10
SECURITY_404_COUNT_THRESHOLD=50
# Office/VPN egress — never auto-blocked (comma-separated IPs/CIDRs)
TRUSTED_ADMIN_IPS=
# Ops-only emergency bulk-unblock token (see docs/security/INCIDENT_530_ATTACK_SPIKE.md)
SECURITY_EMERGENCY_UNBLOCK_TOKEN=
