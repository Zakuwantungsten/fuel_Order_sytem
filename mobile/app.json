{
  "expo": {
    "name": "FuelOrder",
    "slug": "fuelorder",
    "version": "1.0.0",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5ed18b6c-4d7c-44c3-85f0-4ba928534ac1",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "icon": "./assets/icon.png",
    "scheme": "fuelorder",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fuelorder.app"
    },
    "android": {
      "package": "com.fuelorder.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f172a"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/horse-icon.png",
          "color": "#1d4ed8"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://tahfuelorder.dev/api/v1",
      "socketUrl": "https://tahfuelorder.dev",
      "router": {},
      "eas": {
        "projectId": "5ed18b6c-4d7c-44c3-85f0-4ba928534ac1"
      }
    }
  }
}
